# ===== 必填配置 =====
JWT_SECRET_KEY=

# 管理员密码哈希
ADMIN_PASSWORD_HASH=

# ===== 可选配置 =====
DEBUG=false

FACE_THRESHOLD=0.6

CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ===== 数据库（集群模式用 PostgreSQL） =====
DATABASE_URL=postgresql+psycopg2://face:password@localhost:5432/facedb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=facedb
DB_USER=face
DB_PASSWORD=

# ===== Redis 缓存 =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== MinIO 对象存储 =====
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=false
