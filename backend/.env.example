# ===== 必填配置 =====
# JWT密钥: 必须设置，推荐使用32字节随机字符串
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# 管理员密码哈希: 优先使用哈希值
# 生成方法: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
ADMIN_PASSWORD_HASH=

# ===== 可选配置 =====
# 调试模式
DEBUG=false

# 人脸识别阈值 (0.0-1.0, 越小越严格)
FACE_THRESHOLD=0.6

# CORS允许的来源 (逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ===== 兼容旧版配置 (仅首次启动过渡使用，不建议长期使用) =====
# 明文管理员密码 (仅当ADMIN_PASSWORD_HASH未设置时使用)
# ADMIN_PASSWORD=admin123
